\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces Minh họa định tính xu hướng của hai loại đầu phân loại theo nhóm lớp (giá trị trên trục tung là ví dụ minh họa, không phải số liệu thực nghiệm). Đầu tham số suy giảm mạnh ở vùng đuôi do thiếu dữ liệu huấn luyện, trong khi đầu prototype dựa trên NCM duy trì độ ổn định cao hơn. Tier-fusion khai thác bù đắp này bằng cách tăng dần tỉ trọng prototype từ many-shot sang few-shot.}}{21}{figure.caption.62}\protected@file@percent }
\newlabel{fig:tier-fusion-intuition}{{3.1}{21}{Minh họa định tính xu hướng của hai loại đầu phân loại theo nhóm lớp (giá trị trên trục tung là ví dụ minh họa, không phải số liệu thực nghiệm). Đầu tham số suy giảm mạnh ở vùng đuôi do thiếu dữ liệu huấn luyện, trong khi đầu prototype dựa trên NCM duy trì độ ổn định cao hơn. Tier-fusion khai thác bù đắp này bằng cách tăng dần tỉ trọng prototype từ many-shot sang few-shot}{figure.caption.62}{}}
\@writefile{toc}{\contentsline {paragraph}{$\tau $-normalization.}{21}{paragraph*.63}\protected@file@percent }
